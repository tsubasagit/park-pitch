rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 認証済みユーザーのみアクセス可能
    match /blooming_products/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /proposals/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /services/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
